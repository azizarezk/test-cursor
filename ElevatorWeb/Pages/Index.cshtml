@page
@model ElevatorWeb.Pages.IndexModel
@{
    ViewData["Title"] = "LiftPro ERP";
    ViewData["FullBleed"] = "true";
    ViewData["BodyClass"] = "liftpro-page";
    ViewData["HtmlLang"] = "ar";
    ViewData["HtmlDir"] = "rtl";
    ViewData["DataLang"] = "ar";
    ViewData["DataTheme"] = "light";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&family=Almarai:wght@300;400;700;800&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" id="bsLink">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/liftpro.css" asp-append-version="true" />
}

<!-- ═══════════════════════════════════════════════════
     ▌ VIEW: LOGIN
═══════════════════════════════════════════════════ -->
<div id="v-login" class="view auth-view active">
<div class="auth-shell">

  <!-- Hero -->
  <div class="auth-hero">
    <div class="hero-grid"></div>
    <div class="hero-glow-1"></div>
    <div class="hero-glow-2"></div>

    <!-- Elevator shaft animation -->
    <div class="elevator-shaft">
      <div class="shaft-rail shaft-rail-l"></div>
      <div class="shaft-rail shaft-rail-r"></div>
      <div class="rope rope-1"></div>
      <div class="rope rope-2"></div>
      <div class="elevator-box"><i class="bi bi-building-up"></i></div>
      <div class="floor-mark floor-mark-1">B4</div>
      <div class="floor-mark floor-mark-2">B8</div>
      <div class="floor-mark floor-mark-3">B12</div>
      <div class="floor-mark floor-mark-4">B20</div>
      <div class="floor-mark floor-mark-5">G</div>
    </div>

    <div class="hero-content">
      <div class="hero-logo"><i class="bi bi-building-up"></i></div>
      <div class="hero-brand">ليفت<span>برو</span></div>
      <div class="hero-tagline" data-ar="نظام إدارة المصاعد الاحترافي المتكامل" data-en="Professional Elevator Management ERP">نظام إدارة المصاعد الاحترافي المتكامل</div>

      <div class="hero-stats">
        <div class="hero-stat"><div class="hero-stat-val">500+</div><div class="hero-stat-lbl" data-ar="مشروع" data-en="Projects">مشروع</div></div>
        <div class="hero-stat"><div class="hero-stat-val">99%</div><div class="hero-stat-lbl" data-ar="دقة" data-en="Accuracy">دقة</div></div>
        <div class="hero-stat"><div class="hero-stat-val">24/7</div><div class="hero-stat-lbl" data-ar="دعم" data-en="Support">دعم</div></div>
      </div>

      <div class="hero-features">
        <div class="hero-feat"><i class="bi bi-shield-check"></i><span data-ar="صلاحيات متعددة المستويات وحماية كاملة" data-en="Multi-level permissions & full security">صلاحيات متعددة المستويات وحماية كاملة</span></div>
        <div class="hero-feat"><i class="bi bi-graph-up-arrow"></i><span data-ar="تقارير وتحليلات لحظية تفاعلية" data-en="Real-time interactive analytics & reports">تقارير وتحليلات لحظية تفاعلية</span></div>
        <div class="hero-feat"><i class="bi bi-translate"></i><span data-ar="دعم كامل للغتين العربية والإنجليزية" data-en="Full Arabic & English RTL/LTR support">دعم كامل للغتين العربية والإنجليزية</span></div>
        <div class="hero-feat"><i class="bi bi-phone"></i><span data-ar="تصميم متجاوب لجميع الأجهزة" data-en="Fully responsive for all devices">تصميم متجاوب لجميع الأجهزة</span></div>
      </div>
    </div>
  </div>

  <!-- Form side -->
  <div class="auth-form-side">
    <div class="lang-switcher-auth">
      <button class="lang-pill active" id="lp-ar" onclick="setLang('ar')">عربي</button>
      <button class="lang-pill" id="lp-en" onclick="setLang('en')">English</button>
    </div>

    <div class="auth-form-box">
      <div class="form-eyebrow"><i class="bi bi-building-up"></i> <span data-ar="ليفت برو ERP" data-en="LiftPro ERP">ليفت برو ERP</span></div>
      <h1 class="form-h1" data-ar="تسجيل الدخول" data-en="Welcome Back">تسجيل الدخول</h1>
      <p class="form-sub" data-ar="أدخل بياناتك للوصول إلى لوحة التحكم" data-en="Enter your credentials to access the dashboard">أدخل بياناتك للوصول إلى لوحة التحكم</p>

      <div id="login-alert" style="display:none"></div>

      <form onsubmit="handleLogin(event)" novalidate>
        <div class="f-group">
          <label class="f-label" data-ar="البريد الإلكتروني أو اسم المستخدم" data-en="Email or Username">البريد الإلكتروني أو اسم المستخدم</label>
          <div class="f-wrap">
            <input class="f-input" type="text" id="l-user" autocomplete="username" placeholder="admin@@liftpro.com">
            <i class="bi bi-person f-icon"></i>
          </div>
        </div>

        <div class="f-group">
          <label class="f-label" data-ar="كلمة المرور" data-en="Password">كلمة المرور</label>
          <div class="f-wrap">
            <input class="f-input" type="password" id="l-pass" autocomplete="current-password" placeholder="••••••••" style="padding-left:44px">
            <i class="bi bi-lock f-icon"></i>
            <button type="button" class="f-eye" onclick="togglePwd('l-pass',this)"><i class="bi bi-eye-slash"></i></button>
          </div>
        </div>

        <div class="f-meta">
          <label class="f-check">
            <input type="checkbox" id="remember">
            <span class="f-check-lbl" data-ar="تذكرني" data-en="Remember me">تذكرني</span>
          </label>
          <span class="f-link" onclick="goView('v-forgot')" data-ar="نسيت كلمة المرور؟" data-en="Forgot password?">نسيت كلمة المرور؟</span>
        </div>

        <button type="submit" class="btn-submit" id="login-btn">
          <div class="spin"></div>
          <span class="btn-txt"><i class="bi bi-box-arrow-in-right"></i> <span data-ar="دخول" data-en="Sign In">دخول</span></span>
        </button>
      </form>

      <div class="demo-box">
        <div class="demo-box-title" data-ar="بيانات تجريبية للعرض:" data-en="Demo credentials:">بيانات تجريبية للعرض:</div>
        <div><span data-ar="المستخدم:" data-en="User:">المستخدم:</span> <code>admin@@liftpro.com</code></div>
        <div><span data-ar="كلمة المرور:" data-en="Password:">كلمة المرور:</span> <code>Admin@@123</code></div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- ═══════════════════════════════════════════════════
     ▌ VIEW: FORGOT PASSWORD
═══════════════════════════════════════════════════ -->
<div id="v-forgot" class="view auth-view">
<div class="auth-shell">
  <div class="auth-hero" style="background:linear-gradient(175deg,#040d1a,#071525,#0d2847)">
    <div class="hero-grid"></div>
    <div class="hero-glow-1"></div>
    <div class="elevator-shaft">
      <div class="shaft-rail shaft-rail-l"></div><div class="shaft-rail shaft-rail-r"></div>
      <div class="rope rope-1"></div><div class="rope rope-2"></div>
      <div class="elevator-box" style="animation-duration:9s"><i class="bi bi-key"></i></div>
      <div class="floor-mark floor-mark-1">B4</div><div class="floor-mark floor-mark-3">B12</div><div class="floor-mark floor-mark-5">G</div>
    </div>
    <div class="hero-content">
      <div class="hero-logo" style="background:linear-gradient(135deg,#059669,#047857)"><i class="bi bi-shield-lock"></i></div>
      <div class="hero-brand">استعادة <span>الوصول</span></div>
      <div class="hero-tagline" data-ar="سنرسل لك رابط الاستعادة فوراً" data-en="We'll send you a reset link instantly">سنرسل لك رابط الاستعادة فوراً</div>
      <div style="margin-top:32px;padding:20px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:14px">
        <div style="display:flex;flex-direction:column;gap:12px">
          <div style="display:flex;gap:10px;align-items:flex-start"><i class="bi bi-1-circle-fill" style="color:var(--gold-300);font-size:18px;flex-shrink:0;margin-top:1px"></i><div style="font-size:13px;color:rgba(255,255,255,.65)" data-ar="أدخل بريدك الإلكتروني المسجل في النظام" data-en="Enter your registered email address">أدخل بريدك الإلكتروني المسجل في النظام</div></div>
          <div style="display:flex;gap:10px;align-items:flex-start"><i class="bi bi-2-circle-fill" style="color:var(--gold-300);font-size:18px;flex-shrink:0;margin-top:1px"></i><div style="font-size:13px;color:rgba(255,255,255,.65)" data-ar="افتح البريد وانقر على رابط الاستعادة" data-en="Open your email and click the reset link">افتح البريد وانقر على رابط الاستعادة</div></div>
          <div style="display:flex;gap:10px;align-items:flex-start"><i class="bi bi-3-circle-fill" style="color:var(--gold-300);font-size:18px;flex-shrink:0;margin-top:1px"></i><div style="font-size:13px;color:rgba(255,255,255,.65)" data-ar="عيّن كلمة مرور جديدة وآمنة" data-en="Set a new secure password">عيّن كلمة مرور جديدة وآمنة</div></div>
        </div>
        <div style="margin-top:14px;padding-top:14px;border-top:1px solid rgba(255,255,255,.07);font-size:11.5px;color:rgba(255,255,255,.35)" data-ar="⏱ الرابط صالح لمدة 30 دقيقة فقط" data-en="⏱ The link expires in 30 minutes">⏱ الرابط صالح لمدة 30 دقيقة فقط</div>
      </div>
    </div>
  </div>

  <div class="auth-form-side">
    <div class="lang-switcher-auth">
      <button class="lang-pill active" onclick="setLang('ar')">عربي</button>
      <button class="lang-pill" onclick="setLang('en')">English</button>
    </div>
    <div class="auth-form-box">
      <button class="back-link" onclick="goView('v-login')"><i class="bi bi-arrow-right"></i> <span data-ar="العودة لتسجيل الدخول" data-en="Back to sign in">العودة لتسجيل الدخول</span></button>
      <div class="form-eyebrow" style="background:var(--success-l);color:#065f46"><i class="bi bi-envelope-check"></i> <span data-ar="استعادة كلمة المرور" data-en="Password Recovery">استعادة كلمة المرور</span></div>
      <h1 class="form-h1" data-ar="نسيت كلمة المرور؟" data-en="Forgot Password?">نسيت كلمة المرور؟</h1>
      <p class="form-sub" data-ar="أدخل بريدك الإلكتروني وسنرسل لك رابط الاستعادة" data-en="Enter your email and we'll send you a reset link">أدخل بريدك الإلكتروني وسنرسل لك رابط الاستعادة</p>

      <div id="forgot-alert" style="display:none"></div>

      <form onsubmit="handleForgot(event)" novalidate>
        <div class="f-group">
          <label class="f-label" data-ar="البريد الإلكتروني" data-en="Email Address">البريد الإلكتروني</label>
          <div class="f-wrap">
            <input class="f-input" type="email" id="f-email" placeholder="email@@example.com">
            <i class="bi bi-envelope f-icon"></i>
          </div>
        </div>
        <button type="submit" class="btn-submit" id="forgot-btn" style="background:linear-gradient(135deg,#065f46,var(--success))">
          <div class="spin"></div>
          <span class="btn-txt"><i class="bi bi-send"></i> <span data-ar="إرسال رابط الاستعادة" data-en="Send Reset Link">إرسال رابط الاستعادة</span></span>
        </button>
      </form>
    </div>
  </div>
</div>
</div>

<!-- ═══════════════════════════════════════════════════
     ▌ VIEW: RESET PASSWORD
═══════════════════════════════════════════════════ -->
<div id="v-reset" class="view auth-view">
<div class="auth-shell">
  <div class="auth-hero" style="background:linear-gradient(175deg,#040d1a,#1e1040,#2d1060)">
    <div class="hero-grid"></div>
    <div class="elevator-shaft">
      <div class="shaft-rail shaft-rail-l"></div><div class="shaft-rail shaft-rail-r"></div>
      <div class="rope rope-1"></div><div class="rope rope-2"></div>
      <div class="elevator-box" style="animation-duration:5s"><i class="bi bi-shield-lock"></i></div>
      <div class="floor-mark floor-mark-2">B8</div><div class="floor-mark floor-mark-4">B20</div>
    </div>
    <div class="hero-content">
      <div class="hero-logo" style="background:linear-gradient(135deg,var(--purple),#5b21b6)"><i class="bi bi-key-fill"></i></div>
      <div class="hero-brand">كلمة مرور <span>جديدة</span></div>
      <div class="hero-tagline" data-ar="اختر كلمة مرور قوية وفريدة" data-en="Choose a strong and unique password">اختر كلمة مرور قوية وفريدة</div>
      <div style="margin-top:32px;padding:20px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:14px">
        <div style="font-size:11px;color:rgba(255,255,255,.4);margin-bottom:12px;letter-spacing:.5px;font-weight:600" data-ar="متطلبات كلمة المرور" data-en="PASSWORD REQUIREMENTS">متطلبات كلمة المرور</div>
        <div style="display:flex;flex-direction:column;gap:9px">
          <div style="display:flex;gap:9px;align-items:center;font-size:12.5px;color:rgba(255,255,255,.6)"><i class="bi bi-check-circle-fill" style="color:var(--gold-300);font-size:14px;flex-shrink:0"></i> <span data-ar="8 أحرف على الأقل" data-en="At least 8 characters">8 أحرف على الأقل</span></div>
          <div style="display:flex;gap:9px;align-items:center;font-size:12.5px;color:rgba(255,255,255,.6)"><i class="bi bi-check-circle-fill" style="color:var(--gold-300);font-size:14px;flex-shrink:0"></i> <span data-ar="حرف كبير وحرف صغير" data-en="Upper & lowercase letters">حرف كبير وحرف صغير</span></div>
          <div style="display:flex;gap:9px;align-items:center;font-size:12.5px;color:rgba(255,255,255,.6)"><i class="bi bi-check-circle-fill" style="color:var(--gold-300);font-size:14px;flex-shrink:0"></i> <span data-ar="رقم واحد على الأقل" data-en="At least one number">رقم واحد على الأقل</span></div>
          <div style="display:flex;gap:9px;align-items:center;font-size:12.5px;color:rgba(255,255,255,.6)"><i class="bi bi-check-circle-fill" style="color:var(--gold-300);font-size:14px;flex-shrink:0"></i> <span data-ar="رمز خاص مثل @@#$" data-en="Special character like @@#$">رمز خاص مثل @@#$</span></div>
        </div>
      </div>
    </div>
  </div>

  <div class="auth-form-side">
    <div class="lang-switcher-auth">
      <button class="lang-pill active" onclick="setLang('ar')">عربي</button>
      <button class="lang-pill" onclick="setLang('en')">English</button>
    </div>
    <div class="auth-form-box">
      <button class="back-link" onclick="goView('v-login')"><i class="bi bi-arrow-right"></i> <span data-ar="العودة لتسجيل الدخول" data-en="Back to sign in">العودة لتسجيل الدخول</span></button>
      <div class="form-eyebrow" style="background:var(--purple-l);color:#4c1d95"><i class="bi bi-lock-fill"></i> <span data-ar="تعيين كلمة مرور جديدة" data-en="Reset Password">تعيين كلمة مرور جديدة</span></div>
      <h1 class="form-h1" data-ar="تعيين كلمة مرور جديدة" data-en="Reset Your Password">تعيين كلمة مرور جديدة</h1>
      <p class="form-sub" data-ar="أدخل كلمة المرور الجديدة وتأكيدها" data-en="Enter and confirm your new password">أدخل كلمة المرور الجديدة وتأكيدها</p>

      <div id="reset-alert" style="display:none"></div>

      <form onsubmit="handleReset(event)" novalidate>
        <div class="f-group">
          <label class="f-label" data-ar="كلمة المرور الجديدة" data-en="New Password">كلمة المرور الجديدة</label>
          <div class="f-wrap">
            <input class="f-input" type="password" id="r-pass1" placeholder="••••••••" style="padding-left:44px" oninput="checkStrength(this.value)">
            <i class="bi bi-lock f-icon"></i>
            <button type="button" class="f-eye" onclick="togglePwd('r-pass1',this)"><i class="bi bi-eye-slash"></i></button>
          </div>
        </div>

        <div class="strength-wrap">
          <div class="strength-bars">
            <div class="strength-bar" id="sb1"></div>
            <div class="strength-bar" id="sb2"></div>
            <div class="strength-bar" id="sb3"></div>
            <div class="strength-bar" id="sb4"></div>
          </div>
          <div class="strength-lbl" id="strength-lbl"></div>
        </div>

        <div class="f-group">
          <label class="f-label" data-ar="تأكيد كلمة المرور" data-en="Confirm Password">تأكيد كلمة المرور</label>
          <div class="f-wrap">
            <input class="f-input" type="password" id="r-pass2" placeholder="••••••••" style="padding-left:44px">
            <i class="bi bi-lock-fill f-icon"></i>
            <button type="button" class="f-eye" onclick="togglePwd('r-pass2',this)"><i class="bi bi-eye-slash"></i></button>
          </div>
        </div>

        <button type="submit" class="btn-submit" id="reset-btn" style="background:linear-gradient(135deg,#4c1d95,var(--purple))">
          <div class="spin"></div>
          <span class="btn-txt"><i class="bi bi-shield-check"></i> <span data-ar="تعيين كلمة المرور" data-en="Reset Password">تعيين كلمة المرور</span></span>
        </button>
      </form>
    </div>
  </div>
</div>
</div>

<!-- ═══════════════════════════════════════════════════
     ▌ VIEW: DASHBOARD
═══════════════════════════════════════════════════ -->
<div id="v-dash" class="view dash-view">
<div class="dash-shell">

  <!-- Mobile overlay -->
  <div class="mob-overlay" id="mob-overlay" onclick="closeSidebar()"></div>

  <!-- ═══ SIDEBAR ═══ -->
  <aside class="sidebar" id="sidebar">
    <div class="sb-brand">
      <div class="sb-logo-mark"><i class="bi bi-building-up"></i></div>
      <div class="sb-brand-text">
        <div class="sb-brand-name">ليفت<span>برو</span></div>
        <div class="sb-brand-ver" data-ar="نظام إدارة المصاعد v1.0" data-en="Elevator ERP v1.0">نظام إدارة المصاعد v1.0</div>
      </div>
    </div>

    <nav class="sb-nav">
      <div class="sb-group-label" data-ar="القائمة الرئيسية" data-en="MAIN">القائمة الرئيسية</div>
      <div class="sb-item"><a class="sb-link active" href="#"><span class="sb-link-icon"><i class="bi bi-speedometer2"></i></span><span class="sb-link-txt" data-ar="لوحة التحكم" data-en="Dashboard">لوحة التحكم</span></a></div>

      <div class="sb-group-label" data-ar="إدارة الأعمال" data-en="BUSINESS">إدارة الأعمال</div>
      <div class="sb-item"><a class="sb-link" href="#"><span class="sb-link-icon"><i class="bi bi-folder2-open"></i></span><span class="sb-link-txt" data-ar="المشاريع" data-en="Projects">المشاريع</span><span class="sb-badge">8</span></a></div>
      <div class="sb-item"><a class="sb-link" href="#"><span class="sb-link-icon"><i class="bi bi-file-earmark-text"></i></span><span class="sb-link-txt" data-ar="عروض الأسعار" data-en="Quotations">عروض الأسعار</span><span class="sb-badge">3</span></a></div>
      <div class="sb-item"><a class="sb-link" href="#"><span class="sb-link-icon"><i class="bi bi-file-earmark-ruled"></i></span><span class="sb-link-txt" data-ar="العقود" data-en="Contracts">العقود</span></a></div>
      <div class="sb-item"><a class="sb-link" href="#"><span class="sb-link-icon"><i class="bi bi-buildings"></i></span><span class="sb-link-txt" data-ar="العملاء" data-en="Clients">العملاء</span></a></div>

      <div class="sb-group-label" data-ar="الإدارة المالية" data-en="FINANCE">الإدارة المالية</div>
      <div class="sb-item"><a class="sb-link" href="#"><span class="sb-link-icon"><i class="bi bi-cash-coin"></i></span><span class="sb-link-txt" data-ar="الحسابات" data-en="Accounts">الحسابات</span><span class="sb-badge warn">5</span></a></div>
      <div class="sb-item"><a class="sb-link" href="#"><span class="sb-link-icon"><i class="bi bi-receipt"></i></span><span class="sb-link-txt" data-ar="الفواتير" data-en="Invoices">الفواتير</span></a></div>

      <div class="sb-group-label" data-ar="العمليات" data-en="OPERATIONS">العمليات</div>
